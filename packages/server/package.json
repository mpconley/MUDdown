{
  "name": "@muddown/server",
  "version": "0.1.0",
  "description": "MUDdown game server with WebSocket transport",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "node --watch --env-file-if-exists=.env dist/index.js",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@muddown/parser": "*",
    "@muddown/shared": "*",
    "better-sqlite3": "^12.8.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/ws": "^8.5.10",
    "vitest": "^4.1.2"
  },
  "license": "MIT"
}
