---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="MUDdown — A modern MUD platform using Markdown as the universal game markup language" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <style is:global>
      @import "../styles/global.css";
    </style>
  </head>
  <body>
    <header>
      <div class="container">
        <h1><span>MUD</span>down</h1>
        <nav>
          <a href="/">Home</a>
          <a href="/spec">Specification</a>
          <a href="/play">Play</a>
          <a href="https://github.com/MUDdown/MUDdown">GitHub</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="container">
        <p>&copy; 2026 MUDdown Contributors &middot; MIT License &middot; <a href="https://github.com/MUDdown/MUDdown">Source on GitHub</a></p>
      </div>
    </footer>
  </body>
</html>
