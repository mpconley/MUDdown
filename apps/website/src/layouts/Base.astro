---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="MUDdown — A modern MUD platform using Markdown as the universal game markup language" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <style is:global>
      @import "../styles/global.css";
    </style>
  </head>
  <body>
    <header>
      <div class="container">
        <h1>
          <svg
            class="logo-mark"
            width="28"
            height="28"
            viewBox="0 0 512 512"
            aria-hidden="true"
          >
            <rect width="512" height="512" rx="64" fill="#5ccfe6" />
            <text
              x="256"
              y="256"
              text-anchor="middle"
              dominant-baseline="central"
              font-family="'JetBrains Mono',monospace"
              font-weight="700"
              font-size="280"
            >
              <tspan fill="#0a0e14">#Md</tspan>
            </text>
          </svg>
          <span class="logo-text"><span>MUD</span>down</span>
        </h1>
        <nav>
          <a href="/">Home</a>
          <a href="/features">Features</a>
          <a href="/spec">Specification</a>
          <a href="/games">Games</a>
          <a href="/play">Play</a>
          <a href="https://discord.gg/mDFcMT3egK" target="_blank" rel="noopener noreferrer">Discord</a>
          <a href="https://github.com/MUDdown/MUDdown" target="_blank" rel="noopener noreferrer">GitHub</a>
          <span id="auth-nav">
            <a href="/login" id="auth-login-link" class="auth-link" style="display:none;">Login</a>
            <span id="auth-user-info" style="display:none;">
              <span id="auth-display-name" class="auth-display-name"></span>
              <button id="auth-logout-btn" class="auth-btn">Logout</button>
            </span>
          </span>
          <!-- Settings (visible only on play page) -->
          <span id="settings-wrap" class="settings-wrap" style="display:none;">
            <button id="settings-btn" class="auth-btn" aria-haspopup="true" aria-expanded="false" aria-label="Settings">⚙</button>
            <div id="settings-dropdown" class="settings-dropdown" style="display:none;">
              <fieldset>
                <legend>Inventory panel</legend>
                <div class="settings-option">
                  <label><input type="radio" name="inv-mode" value="off" checked /> Off</label>
                </div>
                <div class="settings-option">
                  <label><input type="radio" name="inv-mode" value="persistent" /> Sidebar</label>
                </div>
                <div class="settings-option">
                  <label><input type="radio" name="inv-mode" value="overlay" /> Overlay</label>
                </div>
              </fieldset>
              <a href="/privacy" class="settings-link">Privacy Policy</a>
            </div>
          </span>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="container">
        <p>&copy; 2026 StickMUD Entertainment LLC &middot; MIT License &middot; <a href="https://github.com/MUDdown/MUDdown" target="_blank" rel="noopener noreferrer">Source on GitHub</a> &middot; <a href="https://discord.gg/mDFcMT3egK" target="_blank" rel="noopener noreferrer">Discord</a> &middot; <a href="/privacy">Privacy Policy</a> &middot; <a href="/licenses">Licenses</a></p>
      </div>
    </footer>

    <script>
      const API_BASE = import.meta.env.PUBLIC_API_BASE || (location.port ? `${location.protocol}//${location.hostname}:3300` : location.origin);

      async function checkAuth() {
        try {
          const res = await fetch(`${API_BASE}/auth/me`, { credentials: "include" });
          const loginLink = document.getElementById("auth-login-link");
          const userInfo = document.getElementById("auth-user-info");
          const displayName = document.getElementById("auth-display-name");

          if (res.ok) {
            const data = await res.json();
            if (loginLink) loginLink.style.display = "none";
            if (userInfo) userInfo.style.display = "inline";
            if (displayName) {
              displayName.textContent = data.displayName ?? data.activeCharacter?.name ?? "Adventurer";
            }
          } else {
            if (loginLink) loginLink.style.display = "inline";
            if (userInfo) userInfo.style.display = "none";
          }
        } catch (err) {
          console.error("Failed to check auth status:", err);
          // Server not reachable — show login link as fallback
          const loginLink = document.getElementById("auth-login-link");
          if (loginLink) loginLink.style.display = "inline";
        }
      }

      document.getElementById("auth-logout-btn")?.addEventListener("click", async () => {
        try {
          const res = await fetch(`${API_BASE}/auth/logout`, { method: "POST", credentials: "include" });
          if (!res.ok) console.warn(`Logout returned HTTP ${res.status}`);
        } catch (err) {
          console.warn("Logout request failed:", err);
        }
        window.location.reload();
      });

      checkAuth();

      // Show settings gear only on the play page
      if (document.querySelector(".play-section")) {
        const sw = document.getElementById("settings-wrap");
        if (sw) sw.style.display = "inline";
      }
    </script>
  </body>
</html>
