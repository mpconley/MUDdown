---
import Base from "../layouts/Base.astro";
---
<Base title="Play MUDdown">
  <section class="play-section">
    <div id="game-terminal">
      <div id="game-output" role="log" aria-live="polite"></div>
      <div id="game-input-row">
        <span id="game-prompt">&gt;</span>
        <input
          id="game-input"
          type="text"
          placeholder="Type a command..."
          autocomplete="off"
          autofocus
          aria-label="Game command input"
        />
      </div>
    </div>
  </section>

  <script>
    const output = document.getElementById("game-output")!;
    const input = document.getElementById("game-input")! as HTMLInputElement;

    // ── Markdown-lite renderer (handles basic MUDdown for display) ──────

    function escapeHtml(s: string): string {
      return s
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;");
    }

    function renderMuddown(muddown: string): string {
      // Strip container block fences
      let text = muddown
        .replace(/^:::[\w-]+\{[^}]*\}\s*$/gm, "")
        .replace(/^:::[\w-]+\s*$/gm, "")
        .replace(/^:::\s*$/gm, "")
        .trim();

      // Convert Markdown to HTML
      const lines = text.split("\n");
      const html: string[] = [];
      let inList = false;
      let inTable = false;
      let inBlockquote = false;
      let paraLines: string[] = [];

      function flushPara() {
        if (paraLines.length > 0) {
          const content = paraLines.join(" ");
          if (content.trim()) html.push(`<p>${content}</p>`);
          paraLines = [];
        }
      }

      function inlineFormat(line: string): string {
        // Escape HTML first so only our generated markup is injected
        const safe = escapeHtml(line);
        return safe
          .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")
          .replace(/\*([^*]+)\*/g, "<em>$1</em>")
          .replace(/`([^`]+)`/g, "<code>$1</code>")
          .replace(
            /\[([^\]]+)\]\((cmd|go|item|npc|player|help):([^)]*)\)/g,
            '<a href="#" data-scheme="$2" data-target="$3" onclick="handleGameLink(this); return false;">$1</a>'
          )
          .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>');
      }

      for (const raw of lines) {
        const line = inlineFormat(raw);

        // Blockquotes
        if (raw.startsWith("> ")) {
          flushPara();
          if (inList) { html.push("</ul>"); inList = false; }
          if (inTable) { html.push("</table>"); inTable = false; }
          if (!inBlockquote) { html.push("<blockquote>"); inBlockquote = true; }
          html.push(`<p>${inlineFormat(raw.slice(2))}</p>`);
        } else if (raw.trimStart().startsWith("|") && raw.trimEnd().endsWith("|")) {
          // Skip separator rows like |---|---|
          if (raw.match(/^\|[\s\-:|]+\|$/)) continue;
          flushPara();
          if (inBlockquote) { html.push("</blockquote>"); inBlockquote = false; }
          if (inList) { html.push("</ul>"); inList = false; }
          if (!inTable) { html.push("<table>"); inTable = true; }
          const cells = line.split("|").slice(1, -1).map(c => c.trim());
          html.push("<tr>" + cells.map(c => `<td>${c}</td>`).join("") + "</tr>");
        } else if (raw.match(/^#{1,3} /)) {
          flushPara();
          if (inBlockquote) { html.push("</blockquote>"); inBlockquote = false; }
          if (inList) { html.push("</ul>"); inList = false; }
          if (inTable) { html.push("</table>"); inTable = false; }
          const level = raw.match(/^(#+)/)?.[1].length ?? 1;
          const content = line.replace(/^#{1,3} /, "");
          html.push(`<h${level}>${content}</h${level}>`);
        } else if (raw.startsWith("- ")) {
          flushPara();
          if (inBlockquote) { html.push("</blockquote>"); inBlockquote = false; }
          if (inTable) { html.push("</table>"); inTable = false; }
          if (!inList) { html.push("<ul>"); inList = true; }
          html.push(`<li>${line.slice(2)}</li>`);
        } else if (raw.trim() === "") {
          flushPara();
          if (inBlockquote) { html.push("</blockquote>"); inBlockquote = false; }
          if (inList) { html.push("</ul>"); inList = false; }
          if (inTable) { html.push("</table>"); inTable = false; }
        } else {
          paraLines.push(line);
        }
      }
      flushPara();
      if (inBlockquote) html.push("</blockquote>");
      if (inList) html.push("</ul>");
      if (inTable) html.push("</table>");

      return html.join("");
    }

    function appendMessage(muddown: string, className: string) {
      const div = document.createElement("div");
      div.className = className;

      // ARIA: group each block type with a descriptive label.
      // Landmark/live-region roles (main, alert, log, dialog) are NOT used here
      // because #game-output already has role="log" aria-live="polite" — nesting
      // those roles would cause duplicate announcements or landmark violations.
      const blockMatch = muddown.match(/^:::(\w[\w-]*)/m);
      if (blockMatch) {
        const blockLabels: Record<string, string> = {
          room: "Room description",
          system: "System message",
          combat: "Combat update",
          dialogue: "NPC dialogue",
        };
        const label = blockLabels[blockMatch[1]];
        if (label) {
          div.setAttribute("role", "group");
          div.setAttribute("aria-label", label);
        }
      }

      div.innerHTML = renderMuddown(muddown);
      output.appendChild(div);
      requestAnimationFrame(() => {
        output.scrollTop = output.scrollHeight;
      });
    }

    function appendRawHtml(html: string, className: string) {
      const div = document.createElement("div");
      div.className = className;
      div.innerHTML = html;
      output.appendChild(div);
      requestAnimationFrame(() => {
        output.scrollTop = output.scrollHeight;
      });
    }

    // ── Game link handler (exposed globally for onclick) ────────────────

    (window as any).handleGameLink = function (el: HTMLElement) {
      const scheme = el.getAttribute("data-scheme");
      const target = el.getAttribute("data-target");
      if (scheme === "go") {
        sendCommand(`go ${target}`);
      } else if (scheme === "cmd") {
        sendCommand(target ?? "");
      } else if (scheme === "npc") {
        sendCommand(`talk ${target}`);
      } else if (scheme === "item") {
        sendCommand(`examine ${target}`);
      }
      input.scrollIntoView({ block: "end" });
      input.focus();
    };

    // ── WebSocket connection ───────────────────────────────────────────

    const wsProtocol = location.protocol === "https:" ? "wss:" : "ws:";
    const wsUrl = `${wsProtocol}//${location.hostname}:3300`;
    let ws: WebSocket | null = null;
    let reconnectTimer: ReturnType<typeof setTimeout>;

    function connect() {
      appendMessage("*Connecting to Northkeep...*", "system");
      ws = new WebSocket(wsUrl);

      ws.onopen = () => {
        appendMessage("*Connected!*", "system");
      };

      ws.onmessage = (event) => {
        try {
          const msg = JSON.parse(event.data);
          if (typeof msg.muddown !== "string") throw new Error("Missing muddown field");
          const className = msg.type || "narrative";
          appendMessage(msg.muddown, className);
        } catch (err) {
          console.error("Failed to parse server message:", err);
          appendMessage(event.data, "narrative");
        }
      };

      ws.onclose = () => {
        appendMessage("*Disconnected. Reconnecting in 3s...*", "system");
        reconnectTimer = setTimeout(connect, 3000);
      };

      ws.onerror = (event) => {
        console.error("WebSocket error:", event);
        ws?.close();
      };
    }

    function sendCommand(cmd: string) {
      if (!ws || ws.readyState !== WebSocket.OPEN) {
        appendMessage("*Not connected to server.*", "system");
        return;
      }
      const msg = {
        v: 1,
        id: crypto.randomUUID(),
        type: "command",
        timestamp: new Date().toISOString(),
        command: cmd,
      };
      ws.send(JSON.stringify(msg));
    }

    // ── Input handling ─────────────────────────────────────────────────

    const history: string[] = [];
    let historyIndex = -1;

    input.addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        const cmd = input.value.trim();
        if (!cmd) return;
        history.unshift(cmd);
        historyIndex = -1;
        appendRawHtml(`<span style="color:var(--green)">&gt; ${escapeHtml(cmd)}</span>`, "input-echo");
        sendCommand(cmd);
        input.value = "";
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        if (historyIndex < history.length - 1) {
          historyIndex++;
          input.value = history[historyIndex];
        }
      } else if (e.key === "ArrowDown") {
        e.preventDefault();
        if (historyIndex > 0) {
          historyIndex--;
          input.value = history[historyIndex];
        } else {
          historyIndex = -1;
          input.value = "";
        }
      }
    });

    // ── Start ──────────────────────────────────────────────────────────

    connect();
  </script>
</Base>
