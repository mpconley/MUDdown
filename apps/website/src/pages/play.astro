---
import Base from "../layouts/Base.astro";
---
<Base title="Play MUDdown">
  <section class="play-section">
    <!-- Auth gate: shown when not logged in -->
    <div id="auth-gate" class="panel" style="display:none">
      <h2>Welcome to MUDdown</h2>
      <p><a href="/login" class="panel-btn">Login</a> to play with a saved character, or continue as a guest.</p>
      <button id="guest-play-btn" class="panel-btn panel-btn-secondary">Play as Guest</button>
    </div>

    <!-- Character selection: shown when logged in but no active character -->
    <div id="character-panel" class="panel" style="display:none">
      <h2>Choose a Character</h2>
      <div id="character-list"></div>
      <hr class="panel-divider" />
      <h3>Create New Character</h3>
      <form id="create-character-form">
        <label for="char-name">Name</label>
        <input id="char-name" type="text" minlength="2" maxlength="24"
          placeholder="2–24 characters"
          pattern="[a-zA-Z][a-zA-Z0-9 '\-]{0,22}[a-zA-Z0-9]"
          required aria-label="Character name" />

        <fieldset>
          <legend>Class</legend>
          <div class="class-options">
            <label class="class-option">
              <input type="radio" name="charClass" value="warrior" checked />
              <span class="class-label">Warrior</span>
              <span class="class-stats">HP 25 · AC 12 · ATK +3 · DMG 1d6+1</span>
            </label>
            <label class="class-option">
              <input type="radio" name="charClass" value="mage" />
              <span class="class-label">Mage</span>
              <span class="class-stats">HP 15 · AC 8 · ATK +1 · DMG 1d4</span>
            </label>
            <label class="class-option">
              <input type="radio" name="charClass" value="rogue" />
              <span class="class-label">Rogue</span>
              <span class="class-stats">HP 18 · AC 11 · ATK +2 · DMG 1d6</span>
            </label>
            <label class="class-option">
              <input type="radio" name="charClass" value="cleric" />
              <span class="class-label">Cleric</span>
              <span class="class-stats">HP 20 · AC 10 · ATK +2 · DMG 1d4+1</span>
            </label>
          </div>
        </fieldset>

        <div id="create-error" class="form-error" role="alert"></div>
        <button type="submit" class="panel-btn">Create &amp; Play</button>
      </form>
    </div>

    <!-- Game area: terminal + optional inventory sidebar -->
    <div id="game-area" class="game-area" style="display:none">
      <div id="game-terminal">
        <div id="game-output" role="log" aria-live="polite"></div>
        <div id="game-input-row">
          <span id="game-prompt">&gt;</span>
          <input
            id="game-input"
            type="text"
            placeholder="Type a command..."
            autocomplete="off"
            aria-label="Game command input"
          />
        </div>
      </div>

      <!-- Inventory & equipment panel -->
      <aside id="inventory-panel" class="inv-panel inv-persistent" role="complementary" aria-label="Inventory and equipment">
        <div class="inv-header" id="inv-drag-handle">
          <h2>Inventory</h2>
          <button id="inv-close-btn" class="inv-icon-btn" aria-label="Close inventory panel">&times;</button>
        </div>
        <div class="inv-body">
          <section class="inv-section">
            <h3>Equipment</h3>
            <div id="inv-equipment" class="inv-slots">
              <div class="inv-slot" data-slot="weapon">
                <span class="inv-slot-label">Weapon</span>
                <span class="inv-slot-value" id="inv-slot-weapon"><em>empty</em></span>
              </div>
              <div class="inv-slot" data-slot="armor">
                <span class="inv-slot-label">Armor</span>
                <span class="inv-slot-value" id="inv-slot-armor"><em>empty</em></span>
              </div>
              <div class="inv-slot" data-slot="accessory">
                <span class="inv-slot-label">Accessory</span>
                <span class="inv-slot-value" id="inv-slot-accessory"><em>empty</em></span>
              </div>
            </div>
          </section>
          <section class="inv-section">
            <h3>Items</h3>
            <ul id="inv-items" aria-label="Inventory items">
              <li class="inv-empty">Your inventory is empty.</li>
            </ul>
          </section>
          <div id="inv-status" class="inv-status" aria-live="polite"></div>
        </div>
      </aside>
    </div>
  </section>

  <script>
    const API_BASE = import.meta.env.PUBLIC_API_BASE || (location.port ? `${location.protocol}//${location.hostname}:3300` : location.origin);
    const output = document.getElementById("game-output")!;
    const input = document.getElementById("game-input")! as HTMLInputElement;
    const authGate = document.getElementById("auth-gate")!;
    const characterPanel = document.getElementById("character-panel")!;
    const gameArea = document.getElementById("game-area")!;
    const invPanel = document.getElementById("inventory-panel")!;
    const invItemsList = document.getElementById("inv-items")!;
    const invStatus = document.getElementById("inv-status")!;

    // ── Types ───────────────────────────────────────────────────────────

    interface CharacterSummary {
      id: string;
      name: string;
      characterClass: string;
      hp: number;
      maxHp: number;
      xp: number;
    }

    // ── Auth flow ──────────────────────────────────────────────────────

    let isGuest = false;

    async function checkAuthAndRoute(): Promise<void> {
      let me: { activeCharacter?: { name: string } | null } | null = null;
      try {
        const res = await fetch(`${API_BASE}/auth/me`, { credentials: "include" });
        if (!res.ok) { showAuthGate(); return; }
        try {
          me = await res.json();
        } catch (parseErr) {
          console.error("checkAuthAndRoute: /auth/me returned non-JSON body:", parseErr);
          showAuthGate();
          return;
        }
      } catch (err) {
        // Genuine network failure (fetch itself threw)
        console.debug("checkAuthAndRoute: network error:", err);
        showAuthGate();
        return;
      }

      if (me) {
        if (me.activeCharacter) {
          startGame(me.activeCharacter.name);
        } else {
          await showCharacterPanel();
        }
      } else {
        showAuthGate();
      }
    }

    function showAuthGate(): void {
      authGate.style.display = "";
      characterPanel.style.display = "none";
      gameArea.style.display = "none";
    }

    async function showCharacterPanel(): Promise<void> {
      authGate.style.display = "none";
      characterPanel.style.display = "";
      gameArea.style.display = "none";
      await loadCharacterList();
    }

    async function loadCharacterList(): Promise<void> {
      const listEl = document.getElementById("character-list")!;
      try {
        const res = await fetch(`${API_BASE}/auth/characters`, { credentials: "include" });
        if (res.status === 401) { showAuthGate(); return; }
        if (!res.ok) {
          console.error(`loadCharacterList: HTTP ${res.status}`);
          listEl.innerHTML = `<p>Could not load characters (HTTP ${res.status}). <button onclick="location.reload()">Retry</button></p>`;
          return;
        }
        const data = await res.json();
        if (!data.characters?.length) {
          listEl.innerHTML = "<p class=\"text-dim\">No characters yet — create one below.</p>";
          return;
        }
        listEl.innerHTML = (data.characters as CharacterSummary[]).map((c) => `
          <div class="char-row">
            <div class="char-info">
              <strong>${escapeHtml(c.name)}</strong>
              <span class="text-dim">${escapeHtml(c.characterClass)} · HP ${c.hp}/${c.maxHp} · XP ${c.xp}</span>
            </div>
            <button class="panel-btn panel-btn-sm" data-char-id="${escapeHtml(c.id)}">Play</button>
          </div>
        `).join("");

        listEl.querySelectorAll("button[data-char-id]").forEach(btn => {
          btn.addEventListener("click", () => {
            const charId = btn.getAttribute("data-char-id")!;
            const charName = btn.closest(".char-row")?.querySelector("strong")?.textContent ?? undefined;
            selectCharacter(charId, charName);
          });
        });
      } catch (err) {
        console.error("loadCharacterList error:", err);
        listEl.innerHTML = "<p>Could not load characters. <button onclick=\"location.reload()\">Retry</button></p>";
      }
    }

    async function selectCharacter(characterId: string, charName?: string): Promise<void> {
      try {
        const res = await fetch(`${API_BASE}/auth/select-character`, {
          method: "POST",
          credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ characterId }),
        });
        if (res.ok) {
          if (!charName) {
            try {
              const data = await res.json();
              charName = data.name;
            } catch { /* use undefined — startGame will skip banner update */ }
          }
          startGame(charName);
        } else {
          let errMsg = `HTTP ${res.status}`;
          try {
            const errBody = await res.json();
            if (typeof errBody === "object" && errBody !== null && "error" in errBody) {
              errMsg = String((errBody as { error: unknown }).error);
            }
          } catch { /* response was not JSON */ }
          alert(errMsg);
        }
      } catch (err) {
        console.error("selectCharacter: network error:", err);
        alert("Failed to contact server.");
      }
    }

    // ── Character creation form ────────────────────────────────────────

    const createForm = document.getElementById("create-character-form")! as HTMLFormElement;
    const createError = document.getElementById("create-error")!;

    createForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      createError.textContent = "";

      const name = (document.getElementById("char-name")! as HTMLInputElement).value.trim();
      const charClass = (createForm.querySelector('input[name="charClass"]:checked') as HTMLInputElement)?.value;

      if (!name || !charClass) {
        createError.textContent = "Please enter a name and select a class.";
        return;
      }

      try {
        const res = await fetch(`${API_BASE}/auth/create-character`, {
          method: "POST",
          credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ name, characterClass: charClass }),
        });

        let data: { error?: string };
        const responseText = await res.text();
        try {
          data = JSON.parse(responseText);
        } catch {
          data = { error: responseText.trim() || `Server returned non-JSON response (HTTP ${res.status})` };
        }

        if (!res.ok) {
          createError.textContent = data.error || "Failed to create character.";
          return;
        }
        // Auto-selected on server — go play
        startGame(name);
      } catch (err) {
        console.error("createCharacter: network error:", err);
        createError.textContent = "Failed to contact server.";
      }
    });

    // ── Start game (get ticket + connect) ──────────────────────────────

    async function startGame(characterName?: string): Promise<void> {
      authGate.style.display = "none";
      characterPanel.style.display = "none";
      gameArea.style.display = "";
      applyInvMode(currentInvMode);
      input.focus();

      // Update the banner name
      const bannerName = document.getElementById("auth-display-name");

      if (isGuest) {
        if (bannerName) bannerName.textContent = "Guest";
        const loginLink = document.getElementById("auth-login-link");
        const userInfo = document.getElementById("auth-user-info");
        if (loginLink) loginLink.style.display = "none";
        if (userInfo) userInfo.style.display = "inline";
        connect();
        return;
      }

      // Get a WS ticket for authenticated play
      try {
        const res = await fetch(`${API_BASE}/auth/ws-ticket`, { credentials: "include" });
        if (res.ok) {
          const { ticket } = await res.json();
          if (bannerName && characterName) {
            bannerName.textContent = characterName;
          }
          connect(ticket);
        } else {
          const errBody = await res.json().catch(() => ({}));
          const msg = (errBody as { error?: string }).error ?? `Server error (HTTP ${res.status})`;
          appendMessage(`**Could not start session:** ${msg}. Please reload and try again.`, "system");
          showAuthGate();
          return;
        }
      } catch (err) {
        console.error("startGame: failed to get WS ticket:", err);
        appendMessage("**Could not contact server.** Please reload and try again.", "system");
        showAuthGate();
        return;
      }
    }

    // ── Guest button ───────────────────────────────────────────────────

    document.getElementById("guest-play-btn")!.addEventListener("click", () => {
      isGuest = true;
      startGame();
    });

    // ── Markdown-lite renderer (handles basic MUDdown for display) ──────

    function escapeHtml(s: string): string {
      return s
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;");
    }

    function renderMuddown(muddown: string): string {
      // Strip container block fences
      let text = muddown
        .replace(/^:::[\w-]+\{[^}]*\}\s*$/gm, "")
        .replace(/^:::[\w-]+\s*$/gm, "")
        .replace(/^:::\s*$/gm, "")
        .trim();

      // Convert Markdown to HTML
      const lines = text.split("\n");
      const html: string[] = [];
      let inList = false;
      let inTable = false;
      let inBlockquote = false;
      let paraLines: string[] = [];

      function flushPara() {
        if (paraLines.length > 0) {
          const content = paraLines.join(" ");
          if (content.trim()) html.push(`<p>${content}</p>`);
          paraLines = [];
        }
      }

      function inlineFormat(line: string): string {
        // Escape HTML first so only our generated markup is injected
        const safe = escapeHtml(line);
        return safe
          .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")
          .replace(/\*([^*]+)\*/g, "<em>$1</em>")
          .replace(/`([^`]+)`/g, "<code>$1</code>")
          .replace(
            /\[([^\]]+)\]\((cmd|go|item|npc|player|help):([^)]*)\)/g,
            '<a href="#" data-scheme="$2" data-target="$3" onclick="handleGameLink(this); return false;">$1</a>'
          )
          .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>');
      }

      for (const raw of lines) {
        const line = inlineFormat(raw);

        // Blockquotes
        if (raw.startsWith("> ")) {
          flushPara();
          if (inList) { html.push("</ul>"); inList = false; }
          if (inTable) { html.push("</table>"); inTable = false; }
          if (!inBlockquote) { html.push("<blockquote>"); inBlockquote = true; }
          html.push(`<p>${inlineFormat(raw.slice(2))}</p>`);
        } else if (raw.trimStart().startsWith("|") && raw.trimEnd().endsWith("|")) {
          // Skip separator rows like |---|---|
          if (raw.match(/^\|[\s\-:|]+\|$/)) continue;
          flushPara();
          if (inBlockquote) { html.push("</blockquote>"); inBlockquote = false; }
          if (inList) { html.push("</ul>"); inList = false; }
          if (!inTable) { html.push("<table>"); inTable = true; }
          const cells = line.split("|").slice(1, -1).map(c => c.trim());
          html.push("<tr>" + cells.map(c => `<td>${c}</td>`).join("") + "</tr>");
        } else if (raw.match(/^#{1,3} /)) {
          flushPara();
          if (inBlockquote) { html.push("</blockquote>"); inBlockquote = false; }
          if (inList) { html.push("</ul>"); inList = false; }
          if (inTable) { html.push("</table>"); inTable = false; }
          const level = raw.match(/^(#+)/)?.[1].length ?? 1;
          const content = line.replace(/^#{1,3} /, "");
          html.push(`<h${level}>${content}</h${level}>`);
        } else if (raw.startsWith("- ")) {
          flushPara();
          if (inBlockquote) { html.push("</blockquote>"); inBlockquote = false; }
          if (inTable) { html.push("</table>"); inTable = false; }
          if (!inList) { html.push("<ul>"); inList = true; }
          html.push(`<li>${line.slice(2)}</li>`);
        } else if (raw.trim() === "") {
          flushPara();
          if (inBlockquote) { html.push("</blockquote>"); inBlockquote = false; }
          if (inList) { html.push("</ul>"); inList = false; }
          if (inTable) { html.push("</table>"); inTable = false; }
        } else {
          paraLines.push(line);
        }
      }
      flushPara();
      if (inBlockquote) html.push("</blockquote>");
      if (inList) html.push("</ul>");
      if (inTable) html.push("</table>");

      return html.join("");
    }

    function appendMessage(muddown: string, className: string) {
      const div = document.createElement("div");
      div.className = className;

      // ARIA: group each block type with a descriptive label.
      // Landmark/live-region roles (main, alert, log, dialog) are NOT used here
      // because #game-output already has role="log" aria-live="polite" — nesting
      // those roles would cause duplicate announcements or landmark violations.
      const blockMatch = muddown.match(/^:::(\w[\w-]*)/m);
      if (blockMatch) {
        const blockLabels: Record<string, string> = {
          room: "Room description",
          system: "System message",
          combat: "Combat update",
          dialogue: "NPC dialogue",
        };
        const label = blockLabels[blockMatch[1]];
        if (label) {
          div.setAttribute("role", "group");
          div.setAttribute("aria-label", label);
        }
      }

      div.innerHTML = renderMuddown(muddown);
      output.appendChild(div);
      requestAnimationFrame(() => {
        output.scrollTop = output.scrollHeight;
      });
    }

    function appendRawHtml(html: string, className: string) {
      const div = document.createElement("div");
      div.className = className;
      div.innerHTML = html;
      output.appendChild(div);
      requestAnimationFrame(() => {
        output.scrollTop = output.scrollHeight;
      });
    }

    // ── Game link handler (exposed globally for onclick) ────────────────

    (window as any).handleGameLink = function (el: HTMLElement) {
      const scheme = el.getAttribute("data-scheme");
      const target = el.getAttribute("data-target");
      if (scheme === "go") {
        sendCommand(`go ${target}`);
      } else if (scheme === "cmd") {
        sendCommand(target ?? "");
      } else if (scheme === "npc") {
        sendCommand(`talk ${target}`);
      } else if (scheme === "item") {
        sendCommand(`examine ${target}`);
      }
      input.scrollIntoView({ block: "end" });
      input.focus();
    };

    // ── WebSocket connection ───────────────────────────────────────────

    const apiUrl = new URL(API_BASE);
    const wsProtocol = apiUrl.protocol === "https:" ? "wss:" : "ws:";
    const wsHost = `${wsProtocol}//${apiUrl.host}/ws`;
    let ws: WebSocket | null = null;
    let reconnectTimer: ReturnType<typeof setTimeout>;
    let lastTicket: string | undefined;

    function connect(ticket?: string) {
      if (ticket) lastTicket = ticket;
      const url = lastTicket ? `${wsHost}?ticket=${encodeURIComponent(lastTicket)}` : wsHost;
      // Ticket is single-use; clear after first connect attempt
      lastTicket = undefined;

      appendMessage("*Connecting to Northkeep...*", "system");
      ws = new WebSocket(url);

      ws.onopen = () => {
        appendMessage("*Connected!*", "system");
      };

      ws.onmessage = (event) => {
        try {
          const msg = JSON.parse(event.data);
          if (typeof msg.muddown !== "string") throw new Error("Missing muddown field");

          // Handle inventory state updates
          if (msg.meta?.inventoryState) {
            if (isInvState(msg.meta.inventoryState)) {
              renderInventoryState(msg.meta.inventoryState);
            } else {
              console.error("Received malformed inventoryState payload:", msg.meta.inventoryState);
            }
          }

          // Only append non-empty muddown to game output
          if (msg.muddown) {
            const className = msg.type || "narrative";
            appendMessage(msg.muddown, className);
          }
        } catch (err) {
          console.error("Failed to parse server message:", err);
          appendMessage(event.data, "narrative");
        }
      };

      ws.onclose = () => {
        appendMessage("*Disconnected. Reconnecting in 3s...*", "system");
        reconnectTimer = setTimeout(connect, 3000);
      };

      ws.onerror = (event) => {
        console.error("WebSocket error:", event);
        ws?.close();
      };
    }

    function sendCommand(cmd: string) {
      if (!ws || ws.readyState !== WebSocket.OPEN) {
        appendMessage("*Not connected to server.*", "system");
        return;
      }
      const msg = {
        v: 1,
        id: crypto.randomUUID(),
        type: "command",
        timestamp: new Date().toISOString(),
        command: cmd,
      };
      ws.send(JSON.stringify(msg));
    }

    // ── Input handling ─────────────────────────────────────────────────

    const history: string[] = [];
    let historyIndex = -1;

    input.addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        const cmd = input.value.trim();
        if (!cmd) return;
        history.unshift(cmd);
        historyIndex = -1;
        appendRawHtml(`<span style="color:var(--green)">&gt; ${escapeHtml(cmd)}</span>`, "input-echo");
        sendCommand(cmd);
        input.value = "";
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        if (historyIndex < history.length - 1) {
          historyIndex++;
          input.value = history[historyIndex];
        }
      } else if (e.key === "ArrowDown") {
        e.preventDefault();
        if (historyIndex > 0) {
          historyIndex--;
          input.value = history[historyIndex];
        } else {
          historyIndex = -1;
          input.value = "";
        }
      }
    });

    // ── Inventory panel ─────────────────────────────────────────────

    type InvMode = "off" | "persistent" | "overlay";
    const STORAGE_KEY = "muddown_inv_mode";
    const VALID_INV_MODES = new Set<string>(["off", "persistent", "overlay"]);
    let _storedMode: string | null = null;
    try {
      _storedMode = localStorage.getItem(STORAGE_KEY);
    } catch {
      _storedMode = null;
    }
    let currentInvMode: InvMode = (_storedMode && VALID_INV_MODES.has(_storedMode))
      ? (_storedMode as InvMode)
      : "off";

    interface InvItem {
      id: string;
      name: string;
      equippable: boolean;
      usable: boolean;
    }

    interface InvState {
      items: InvItem[];
      equipped: Record<string, { id: string; name: string } | null>;
    }

    function isInvState(v: unknown): v is InvState {
      if (v === null || typeof v !== "object") return false;
      const obj = v as Record<string, unknown>;
      if (!Array.isArray(obj.items)) return false;
      const allItemsValid = obj.items.every(item => {
        if (item === null || typeof item !== "object") return false;
        const it = item as Record<string, unknown>;
        return (
          typeof it.id === "string" &&
          typeof it.name === "string" &&
          typeof it.equippable === "boolean" &&
          typeof it.usable === "boolean"
        );
      });
      if (!allItemsValid) return false;
      const equipped = obj.equipped;
      if (equipped === null || typeof equipped !== "object" || Array.isArray(equipped)) return false;
      return Object.values(equipped as Record<string, unknown>).every(val => {
        if (val === null) return true;
        if (typeof val !== "object") return false;
        const vObj = val as Record<string, unknown>;
        return typeof vObj.id === "string" && typeof vObj.name === "string";
      });
    }

    let lastInvState: InvState | null = null;

    function applyInvMode(mode: InvMode): void {
      currentInvMode = mode;
      try {
        localStorage.setItem(STORAGE_KEY, mode);
      } catch {
        // SecurityError or QuotaExceededError — mode will not persist
      }

      invPanel.classList.remove("inv-persistent", "inv-overlay", "inv-off");

      if (mode === "off") {
        invPanel.classList.add("inv-off");
        invPanel.style.display = "none";
      } else if (mode === "persistent") {
        invPanel.classList.add("inv-persistent");
        invPanel.style.display = "";
        // Reset overlay positioning
        invPanel.style.top = "";
        invPanel.style.left = "";
        invPanel.style.width = "";
        invPanel.style.height = "";
      } else {
        invPanel.classList.add("inv-overlay");
        invPanel.style.display = "";
        // Apply saved overlay position if available
        const saved = localStorage.getItem("muddown_inv_pos");
        if (saved) {
          try {
            const pos = JSON.parse(saved) as unknown;
            if (
              pos !== null &&
              typeof pos === "object" &&
              typeof (pos as Record<string, unknown>).top === "string" &&
              typeof (pos as Record<string, unknown>).left === "string"
            ) {
              const p = pos as Record<string, string>;
              invPanel.style.top = p.top;
              invPanel.style.left = p.left;
              if (p.width) invPanel.style.width = p.width;
              if (p.height) invPanel.style.height = p.height;
            } else {
              console.error("muddown_inv_pos has unexpected shape, discarding:", pos);
              localStorage.removeItem("muddown_inv_pos");
            }
          } catch (err) {
            console.error("Failed to parse saved overlay position, discarding:", err);
            localStorage.removeItem("muddown_inv_pos");
          }
        }
      }

      // Update settings radio inputs
      document.querySelectorAll<HTMLInputElement>("input[name='inv-mode']").forEach(radio => {
        radio.checked = radio.value === mode;
      });
    }

    function renderInventoryState(state: InvState): void {
      lastInvState = state;

      // Equipment slots
      for (const slot of ["weapon", "armor", "accessory"]) {
        const el = document.getElementById(`inv-slot-${slot}`);
        if (!el) continue;
        const eq = state.equipped[slot];
        if (eq) {
          el.innerHTML = `<button class="inv-item-btn" data-action="unequip" data-slot="${escapeHtml(slot)}" title="Unequip ${escapeHtml(eq.name)}">${escapeHtml(eq.name)}</button>`;
        } else {
          el.innerHTML = "<em>empty</em>";
        }
      }

      // Item list
      if (state.items.length === 0) {
        invItemsList.innerHTML = '<li class="inv-empty">Your inventory is empty.</li>';
      } else {
        const equippedIds = new Set(
          Object.values(state.equipped).filter(Boolean).map(e => e!.id)
        );
        invItemsList.innerHTML = state.items.map(item => {
          const isEquipped = equippedIds.has(item.id);
          const actions: string[] = [];
          actions.push(`<button class="inv-action" data-action="examine" data-item="${escapeHtml(item.id)}" title="Examine">🔍</button>`);
          if (item.equippable && !isEquipped) {
            actions.push(`<button class="inv-action" data-action="equip" data-item="${escapeHtml(item.id)}" title="Equip">🛡</button>`);
          }
          if (item.usable) {
            actions.push(`<button class="inv-action" data-action="use" data-item="${escapeHtml(item.id)}" title="Use">✨</button>`);
          }
          if (!isEquipped) {
            actions.push(`<button class="inv-action" data-action="drop" data-item="${escapeHtml(item.id)}" title="Drop">⬇</button>`);
          }
          const eqBadge = isEquipped ? ' <span class="inv-equipped-badge">(equipped)</span>' : "";
          return `<li class="inv-item${isEquipped ? " inv-item-equipped" : ""}"><span class="inv-item-name">${escapeHtml(item.name)}${eqBadge}</span><span class="inv-actions">${actions.join("")}</span></li>`;
        }).join("");
      }

      invStatus.textContent = `${state.items.length} item${state.items.length !== 1 ? "s" : ""}`;
    }

    function handleInvAction(btn: HTMLElement): void {
      const action = btn.getAttribute("data-action");
      const item = btn.getAttribute("data-item");
      const slot = btn.getAttribute("data-slot");

      switch (action) {
        case "examine":
          if (item) {
            sendCommand(`examine ${item}`);
          } else {
            console.error("examine action missing data-item attribute", btn);
          }
          break;
        case "equip":
          if (item) {
            sendCommand(`equip ${item}`);
          } else {
            console.error("equip action missing data-item attribute", btn);
          }
          break;
        case "unequip":
          if (slot) {
            sendCommand(`unequip ${slot}`);
          } else {
            console.error("unequip action missing data-slot attribute", btn);
          }
          break;
        case "use":
          if (item) {
            sendCommand(`use ${item}`);
          } else {
            console.error("use action missing data-item attribute", btn);
          }
          break;
        case "drop":
          if (item) {
            sendCommand(`drop ${item}`);
          } else {
            console.error("drop action missing data-item attribute", btn);
          }
          break;
        default:
          console.error(`handleInvAction: unrecognised action "${action}"`, btn);
          break;
      }
      input.focus();
    }

    // Delegated click listener for inventory actions
    invPanel.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLElement>("[data-action]");
      if (btn) handleInvAction(btn);
    });

    // Close button
    document.getElementById("inv-close-btn")!.addEventListener("click", () => {
      applyInvMode("off");
    });

    // ── Overlay drag ───────────────────────────────────────────────

    const dragHandle = document.getElementById("inv-drag-handle")!;
    let isDragging = false;
    let dragOffsetX = 0;
    let dragOffsetY = 0;

    dragHandle.addEventListener("mousedown", (e) => {
      if (currentInvMode !== "overlay") return;
      if ((e.target as HTMLElement).closest("button")) return;
      isDragging = true;
      const rect = invPanel.getBoundingClientRect();
      dragOffsetX = e.clientX - rect.left;
      dragOffsetY = e.clientY - rect.top;
      invPanel.style.transition = "none";
      e.preventDefault();
    });

    document.addEventListener("mousemove", (e) => {
      if (!isDragging) return;
      invPanel.style.left = `${e.clientX - dragOffsetX}px`;
      invPanel.style.top = `${e.clientY - dragOffsetY}px`;
    });

    document.addEventListener("mouseup", () => {
      if (!isDragging) return;
      isDragging = false;
      invPanel.style.transition = "";
      saveOverlayPosition();
    });

    // Touch support for drag
    dragHandle.addEventListener("touchstart", (e) => {
      if (currentInvMode !== "overlay") return;
      if ((e.target as HTMLElement).closest("button")) return;
      const touch = e.touches[0];
      isDragging = true;
      const rect = invPanel.getBoundingClientRect();
      dragOffsetX = touch.clientX - rect.left;
      dragOffsetY = touch.clientY - rect.top;
      invPanel.style.transition = "none";
    }, { passive: true });

    document.addEventListener("touchmove", (e) => {
      if (!isDragging) return;
      e.preventDefault();
      const touch = e.touches[0];
      invPanel.style.left = `${touch.clientX - dragOffsetX}px`;
      invPanel.style.top = `${touch.clientY - dragOffsetY}px`;
    }, { passive: false });

    document.addEventListener("touchend", () => {
      if (!isDragging) return;
      isDragging = false;
      invPanel.style.transition = "";
      saveOverlayPosition();
    });

    // Save overlay position to localStorage
    function saveOverlayPosition(): void {
      if (currentInvMode !== "overlay") return;
      try {
        localStorage.setItem("muddown_inv_pos", JSON.stringify({
          top: invPanel.style.top,
          left: invPanel.style.left,
          width: invPanel.style.width || "",
          height: invPanel.style.height || "",
        }));
      } catch (err) {
        // QuotaExceededError or SecurityError — position will not persist this session
        console.error("Failed to save overlay position to localStorage:", err);
      }
    }

    // Watch for CSS resize changes on overlay
    if (typeof ResizeObserver !== "undefined") {
      new ResizeObserver(() => {
        if (currentInvMode === "overlay") saveOverlayPosition();
      }).observe(invPanel);
    }

    // ── Settings dropdown ──────────────────────────────────────────

    const settingsBtn = document.getElementById("settings-btn");
    const settingsDropdown = document.getElementById("settings-dropdown");

    settingsBtn?.addEventListener("click", () => {
      const expanded = settingsBtn.getAttribute("aria-expanded") === "true";
      settingsBtn.setAttribute("aria-expanded", String(!expanded));
      if (settingsDropdown) settingsDropdown.style.display = expanded ? "none" : "";
    });

    // Close dropdown on outside click
    document.addEventListener("click", (e) => {
      if (settingsBtn && settingsDropdown && !settingsBtn.contains(e.target as Node) && !settingsDropdown.contains(e.target as Node)) {
        settingsBtn.setAttribute("aria-expanded", "false");
        settingsDropdown.style.display = "none";
      }
    });

    // Close dropdown on Escape
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && settingsDropdown?.style.display !== "none") {
        settingsBtn?.setAttribute("aria-expanded", "false");
        if (settingsDropdown) settingsDropdown.style.display = "none";
        settingsBtn?.focus();
      }
    });

    // Inventory mode radio inputs
    document.querySelectorAll<HTMLInputElement>("input[name='inv-mode']").forEach(radio => {
      radio.addEventListener("change", () => {
        const raw = radio.value;
        if (!VALID_INV_MODES.has(raw)) return;
        applyInvMode(raw as InvMode);
        if (lastInvState) renderInventoryState(lastInvState);
      });
    });

    // Sync initial mode to UI (reflects persisted localStorage value)
    applyInvMode(currentInvMode);

    // ── Start ──────────────────────────────────────────────────────────

    checkAuthAndRoute();
  </script>

  <style>
    .panel {
      max-width: 520px;
      margin: 2rem auto;
      background: var(--bg-surface);
      border: 1px solid #1e2a38;
      border-radius: var(--radius);
      padding: 2rem;
    }
    .panel h2 { margin-bottom: 0.5rem; }
    .panel p { color: var(--text-dim); line-height: 1.5; margin-bottom: 1rem; }
    .panel-btn {
      display: inline-block;
      padding: 0.5rem 1.25rem;
      border: 1px solid var(--accent-dim);
      border-radius: var(--radius);
      background: var(--bg-elevated);
      color: var(--text-bright);
      font-family: var(--font-body);
      font-weight: 600;
      font-size: 0.9rem;
      cursor: pointer;
      text-decoration: none;
      transition: background 0.15s, border-color 0.15s;
    }
    .panel-btn:hover { background: #243040; border-color: var(--green); }
    .panel-btn-secondary { border-color: #2a3444; }
    .panel-btn-sm { padding: 0.35rem 0.85rem; font-size: 0.85rem; }
    .panel-divider { border: none; border-top: 1px solid #1e2a38; margin: 1.5rem 0; }

    /* Character list */
    .char-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.6rem 0;
      border-bottom: 1px solid #1e2a38;
    }
    .char-row:last-child { border-bottom: none; }
    .char-info { display: flex; flex-direction: column; gap: 0.2rem; }
    .text-dim { color: var(--text-dim); font-size: 0.85rem; }

    /* Create character form */
    #create-character-form label { display: block; margin-top: 1rem; font-weight: 600; font-size: 0.9rem; }
    #create-character-form input[type="text"] {
      width: 100%;
      padding: 0.5rem 0.75rem;
      margin-top: 0.25rem;
      background: var(--bg-elevated);
      border: 1px solid #2a3444;
      border-radius: var(--radius);
      color: var(--text-bright);
      font-family: var(--font-body);
      font-size: 0.9rem;
      box-sizing: border-box;
    }
    #create-character-form fieldset { border: none; padding: 0; margin: 1rem 0; }
    #create-character-form legend { font-weight: 600; font-size: 0.9rem; margin-bottom: 0.5rem; }
    .class-options { display: flex; flex-direction: column; gap: 0.4rem; }
    .class-option {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 0.75rem;
      background: var(--bg-elevated);
      border: 1px solid #2a3444;
      border-radius: var(--radius);
      cursor: pointer;
      transition: border-color 0.15s;
    }
    .class-option:has(input:checked) { border-color: var(--green); }
    .class-label { font-weight: 600; min-width: 5rem; }
    .class-stats { color: var(--text-dim); font-size: 0.8rem; font-family: var(--font-mono); }
    .form-error { color: #e55; font-size: 0.85rem; min-height: 1.2em; margin: 0.5rem 0; }
    #create-character-form button[type="submit"] { margin-top: 0.5rem; }
  </style>
</Base>
