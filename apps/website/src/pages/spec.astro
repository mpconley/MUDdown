---
import Base from "../layouts/Base.astro";
import fs from "node:fs";
import path from "node:path";
import { marked } from "marked";

const specPath = path.resolve("../../packages/spec/SPECIFICATION.md");
const specMd = fs.readFileSync(specPath, "utf-8");
let specHtml = await marked(specMd);

// Replace conformance level names with styled badges
const badgeMap: Record<string, string> = {
  "MUDdown Text": "text",
  "MUDdown Interactive": "interactive",
  "MUDdown Full": "full",
};
for (const [label, level] of Object.entries(badgeMap)) {
  specHtml = specHtml.replaceAll(
    `<strong>${label}</strong>`,
    `<span class="conformance-badge conformance-${level}">${label}</span>`,
  );
}
---
<Base title="MUDdown Specification">
  <div class="container spec-content" set:html={specHtml} />
</Base>
