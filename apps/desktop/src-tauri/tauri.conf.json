{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "MUDdown",
  "version": "0.1.0",
  "identifier": "com.muddown.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npx vite dev",
    "beforeBuildCommand": "npx vite build"
  },
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13",
      "entitlements": "Entitlements.plist",
      "dmg": {
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 },
        "windowSize": { "width": 660, "height": 400 }
      }
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MUDdown",
        "width": 1024,
        "height": 768,
        "minWidth": 640,
        "minHeight": 480,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ws: wss: http: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["muddown"]
      }
    },
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMyQkFEQTgzMjYxOUZDOTYKUldTVy9Ca21nOXE2d2pjWTZYMmd2MklKSGg4di9aYVJJdG9odkp1OUQrU0VCU1V2TFhNSWNFSjkK",
      "endpoints": [
        "https://github.com/MUDdown/MUDdown/releases/latest/download/latest.json"
      ]
    }
  }
}
