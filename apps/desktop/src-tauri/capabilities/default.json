{
  "identifier": "muddown-default",
  "description": "Default capability set for MUDdown desktop",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-set-title",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "dialog:default",
    "dialog:allow-ask",
    "notification:default",
    "notification:allow-notify",
    "notification:allow-is-permission-granted",
    "notification:allow-request-permission",
    "store:default",
    "updater:default",
    "deep-link:default",
    "opener:default"
  ]
}
