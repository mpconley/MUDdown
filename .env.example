# MUDdown Server Environment
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# GitHub OAuth (register at https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# GITHUB_CALLBACK_URL=http://localhost:3300/auth/callback  # default; set in production

# Server
# PORT=3300
# MUDDOWN_DB=muddown.sqlite
# WEBSITE_ORIGIN=http://localhost:4321
